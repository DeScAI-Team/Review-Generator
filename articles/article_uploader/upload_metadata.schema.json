{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Upload Metadata Schema",
  "description": "Schema for upload_metadata.json created after successful Arweave uploads",
  "type": "object",
  "required": ["upload_date", "output_dir", "evidence_audit", "review", "overview"],
  "properties": {
    "upload_date": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when upload sequence started"
    },
    "output_dir": {
      "type": "string",
      "description": "Absolute path to the article output directory"
    },
    "evidence_audit": {
      "type": "object",
      "required": ["txid", "url", "tags"],
      "properties": {
        "txid": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{43}$",
          "description": "Arweave transaction ID (43-char base64url)"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://arweave\\.net/[A-Za-z0-9_-]{43}$",
          "description": "Full Arweave gateway URL"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "value"],
            "properties": {
              "name": {
                "type": "string"
              },
              "value": {
                "type": "string"
              }
            }
          },
          "description": "GraphQL tags attached to the upload"
        }
      }
    },
    "review": {
      "type": "object",
      "required": ["txid", "url", "descai_url", "tags"],
      "properties": {
        "txid": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{43}$",
          "description": "Arweave transaction ID"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://arweave\\.net/[A-Za-z0-9_-]{43}$",
          "description": "Arweave gateway URL"
        },
        "descai_url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://descai\\.net/review/[A-Za-z0-9_-]{43}$",
          "description": "DeScAi platform URL for the review"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "value"],
            "properties": {
              "name": {
                "type": "string"
              },
              "value": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "overview": {
      "type": "object",
      "required": ["txid", "url", "tags"],
      "properties": {
        "txid": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{43}$",
          "description": "Arweave transaction ID"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://arweave\\.net/[A-Za-z0-9_-]{43}$",
          "description": "Arweave gateway URL"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "value"],
            "properties": {
              "name": {
                "type": "string"
              },
              "value": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "examples": [
    {
      "upload_date": "2026-05-14T16:28:00.000Z",
      "output_dir": "/path/to/articles/data/Study Name/output",
      "evidence_audit": {
        "txid": "abc123XYZ-_456defGHI789jklMNO012pqrSTU034vwx",
        "url": "https://arweave.net/abc123XYZ-_456defGHI789jklMNO012pqrSTU034vwx",
        "tags": [
          {"name": "doctype", "value": "evidence"},
          {"name": "platform", "value": "ResearchHub"},
          {"name": "category", "value": "Article"},
          {"name": "research_name", "value": "Study Name"},
          {"name": "review_date", "value": "2026-05-14"}
        ]
      },
      "review": {
        "txid": "def456ABC-_789ghiJKL012mnoQRS345tuvWXY678zab",
        "url": "https://arweave.net/def456ABC-_789ghiJKL012mnoQRS345tuvWXY678zab",
        "descai_url": "https://descai.net/review/def456ABC-_789ghiJKL012mnoQRS345tuvWXY678zab",
        "tags": [
          {"name": "doctype", "value": "review"},
          {"name": "platform", "value": "ResearchHub"},
          {"name": "category", "value": "Article"},
          {"name": "research_name", "value": "Study Name"},
          {"name": "review_date", "value": "2026-05-14"}
        ]
      },
      "overview": {
        "txid": "ghi789MNO-_012pqrSTU345vwxYZA678bcDEF901hij",
        "url": "https://arweave.net/ghi789MNO-_012pqrSTU345vwxYZA678bcDEF901hij",
        "tags": [
          {"name": "doctype", "value": "overview"},
          {"name": "platform", "value": "ResearchHub"},
          {"name": "category", "value": "Article"},
          {"name": "research_name", "value": "Study Name"},
          {"name": "review_date", "value": "2026-05-14"}
        ]
      }
    }
  ]
}
