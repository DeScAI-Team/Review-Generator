# Copy to .env and set the path to your Arweave wallet keyfile (JWK JSON).
# Generate/download a keyfile from an Arweave wallet (e.g. ArConnect export, or
# https://arweave.org/wallet ). Never commit the real keyfile or .env.
WALLET_PATH=path/to/your/arweave-keyfile.json

# Optional: address of the wallet above (base64url). crawlers/full-crawl.mjs uses this as
# AGENT_WALLET to fetch the latest crawl-log from Arweave GraphQL (same owner as uploads).
# AGENT_WALLET=
